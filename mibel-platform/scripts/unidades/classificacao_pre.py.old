"""
classificacao_pre.py
────────────────────
Carrega o ficheiro de unidades da OMEL (LISTA_UNIDADES.csv) e classifica
cada unidade com:
  - is_pre        → True se a unidade é de Regime Especial (renovável/cogeração)
  - categoria_pre → categoria normalizada (ex: SOLAR_FOT, EOLICA, HIDRICA, ...)
  - is_convencional → True para geração convencional (nuclear, CC, carvão, ...)

Baseado na análise real do ficheiro OMEL de Março 2026:
  • Não existe coluna "PRE/PRO" explícita — a classificação é feita pela
    coluna TECNOLOGIA usando o prefixo "RE Mercado" e "RE Tarifa CUR".
  • TIPO_UNIDAD == "GENERACION" cobre toda a geração (RE e convencional).
  • Tecnologias convencionais identificadas: Ciclo Combinado, Nuclear,
    Hidráulica Generación, Hulla Antracita, Gas, Carbón de Importación.
"""

import pandas as pd
import unicodedata


# ─────────────────────────────────────────────────────────────────────────────
#  MAPA: tecnologia normalizada → categoria PRE
#  Chave: substring que deve estar contida na tecnologia (após normalização)
#  Valor: categoria canónica usada no resto do pipeline
# ─────────────────────────────────────────────────────────────────────────────
MAPA_CATEGORIA_PRE = {
    # ── Solar ────────────────────────────────────────────────────────────────
    "SOLAR FOTOVOLTICA":  "SOLAR_FOT",   # RE Mercado Solar Fotovoltáica  (1282)
    "SOLAR FOTOVOLT":     "SOLAR_FOT",   # variante de encoding
    "SOLAR TERMICA":      "SOLAR_TER",   # RE Mercado Solar Térmica        (52)
    "SOLAR TRMICA":       "SOLAR_TER",   # variante normalizada sem acento
    # ── Eólica ───────────────────────────────────────────────────────────────
    "ELICA MARINA":       "EOLICA_MARINA",  # RE Mercado Eólica Marina     (1)
    "ELICA":              "EOLICA",          # RE Mercado Eólica            (432)
    # ── Hídrica ──────────────────────────────────────────────────────────────
    "HIDRULICA":          "HIDRICA",      # RE Mercado Hidráulica           (216)
                                          # RE Tar. CUR Hidráulica           (4)
    # ── Térmica Renovável (biomassa, biogás, resíduos renováveis) ─────────────
    "TRMICA RENOVABLE":   "TERMICA_RENOV",  # RE Mercado Térmica Renovable (103)
    "TRMICA RENOVAB":     "TERMICA_RENOV",  # variante
    # ── Térmica Não Renovável (cogeração, resíduos não renováveis) ────────────
    "TRMICA NO RENOV":    "TERMICA_NREN",   # RE Mercado Térmica no Renov. (430)
    # ── Geotérmica ───────────────────────────────────────────────────────────
    "GEOTRMICA":          "GEOTERMICA",     # RE Mercado Geotérmica          (5)
    # ── Híbrida renovável ────────────────────────────────────────────────────
    "HBRIDA RENOV":       "HIBRIDA_RENOV",  # Híbrida Renovável             (10)
                                             # Híbrida Renov.-Almacenamento   (4)
                                             # Híbrida Renov.-Térmica         (2)
    # ── Tarifa CUR (unidades ainda em tarifa regulada, mas RE) ───────────────
    "RE TARIFA CUR":      "RE_TARIFA_CUR",  # RE Tarifa CUR (uof)           (52)
                                             # RE Tar. CUR Eólica, Solar, ...
}

# Tecnologias convencionais (PRO) — excluídas do PRE
CONVENCIONAL_KEYWORDS = {
    "CICLO COMBINADO",
    "NUCLEAR",
    "HIDRULICA GENERACIN",   # hídrica de grande dimensão, regime ordinário
    "HULLA ANTRACITA",
    "CARBN DE IMPORTACIN",
    "GAS",
}


# ─────────────────────────────────────────────────────────────────────────────
#  FUNÇÕES AUXILIARES
# ─────────────────────────────────────────────────────────────────────────────

def _norm(s: str) -> str:
    """Remove acentos, converte para uppercase, strip."""
    return (unicodedata.normalize("NFD", str(s))
            .encode("ascii", "ignore")
            .decode()
            .upper()
            .strip())


def _classifica_tecnologia(tecnologia_norm: str) -> tuple[bool, str | None]:
    """
    Dada a tecnologia normalizada, devolve (is_pre, categoria).
    Retorna (False, None) se não for PRE.
    """
    # Tecnologias que começam com "RE MERCADO" ou "RE TAR" são sempre PRE
    is_re_prefix = (
        tecnologia_norm.startswith("RE MERCADO")
        or tecnologia_norm.startswith("RE TAR")
        or tecnologia_norm.startswith("RE TARIFA")
    )

    if not is_re_prefix:
        # Pode ainda ser híbrida renovável (não tem prefixo "RE")
        if "HBRIDA RENOV" in tecnologia_norm:
            return True, "HIBRIDA_RENOV"
        return False, None

    # Mapear para categoria
    for keyword, categoria in MAPA_CATEGORIA_PRE.items():
        if keyword in tecnologia_norm:
            return True, categoria

    # Prefixo RE mas sem mapeamento explícito → RE_OUTRO
    return True, "RE_OUTRO"


# ─────────────────────────────────────────────────────────────────────────────
#  FUNÇÃO PRINCIPAL
# ─────────────────────────────────────────────────────────────────────────────

def carrega_unidades(path_csv: str) -> pd.DataFrame:
    """
    Lê o ficheiro LISTA_UNIDADES.csv da OMEL e devolve um DataFrame com:

    CODIGO  |  DESCRIPCION  |  AGENTE_PROPIETARIO  |  TIPO_UNIDAD  |
    ZONA_FRONTERA  |  TECNOLOGIA  |  is_pre  |  categoria_pre  |  is_convencional

    Parâmetros
    ──────────
    path_csv : caminho para LISTA_UNIDADES.csv (separador ';', encoding latin-1)

    Devolve
    ───────
    DataFrame com 3895 linhas (março 2026) e colunas descritas acima.
    """
    # ── 1. Leitura robusta (header na linha 3) ────────────────────────────────
    df_raw = pd.read_csv(path_csv, sep=";", encoding="latin-1", header=None)

    hdr_row = next(
        i for i, row in df_raw.iterrows()
        if row.astype(str).str.upper().str.contains("CODIGO").any()
        and row.astype(str).str.upper().str.contains("TIPO").any()
    )

    df = pd.read_csv(
        path_csv, sep=";", encoding="latin-1",
        skiprows=hdr_row + 1, header=None
    )
    df = df.iloc[:, :7].copy()
    df.columns = [
        "CODIGO", "DESCRIPCION", "AGENTE_PROPIETARIO",
        "PORCENTAJE_PROPIEDAD", "TIPO_UNIDAD", "ZONA_FRONTERA", "TECNOLOGIA"
    ]

    # ── 2. Limpeza básica ─────────────────────────────────────────────────────
    df = (df
          .dropna(subset=["CODIGO"])
          .query("CODIGO.str.strip() != '' and CODIGO.str.strip() != 'nan'",
                 engine="python")
          .reset_index(drop=True))

    for col in ["CODIGO", "TIPO_UNIDAD", "TECNOLOGIA", "ZONA_FRONTERA", "DESCRIPCION"]:
        df[col] = df[col].astype(str).str.strip()

    # ── 3. Colunas normalizadas (internas, para matching) ─────────────────────
    df["_TIPO_NORM"]   = df["TIPO_UNIDAD"].apply(_norm)
    df["_TECNOL_NORM"] = df["TECNOLOGIA"].apply(_norm)

    # ── 4. Classificação PRE ──────────────────────────────────────────────────
    # Critério: TIPO_UNIDAD == GENERACION  AND  tecnologia com prefixo "RE *"
    # (ou híbrida renovável)
    resultado = df["_TECNOL_NORM"].apply(_classifica_tecnologia)
    df["is_pre"]        = resultado.apply(lambda x: x[0]) & (df["_TIPO_NORM"] == "GENERACION")
    df["categoria_pre"] = resultado.apply(lambda x: x[1] if x[0] else None)
    df.loc[~df["is_pre"], "categoria_pre"] = None

    # ── 5. Flag convencional ──────────────────────────────────────────────────
    df["is_convencional"] = (
        (df["_TIPO_NORM"] == "GENERACION") & (~df["is_pre"])
    )

    # ── 6. Remover colunas internas ───────────────────────────────────────────
    df = df.drop(columns=["_TIPO_NORM", "_TECNOL_NORM"])

    return df


def resumo_classificacao(df: pd.DataFrame) -> None:
    """Imprime um resumo legível da classificação."""
    total    = len(df)
    n_pre    = df["is_pre"].sum()
    n_conv   = df["is_convencional"].sum()
    n_outros = total - n_pre - n_conv

    print(f"\n{'='*60}")
    print(f"  RESUMO DE CLASSIFICAÇÃO DE UNIDADES OMEL")
    print(f"{'='*60}")
    print(f"  Total de unidades:        {total:>6d}")
    print(f"  PRE (renovável/cog.):     {n_pre:>6d}  ({n_pre/total*100:.1f}%)")
    print(f"  Convencional (PRO):       {n_conv:>6d}  ({n_conv/total*100:.1f}%)")
    print(f"  Outros (comerc., etc.):   {n_outros:>6d}  ({n_outros/total*100:.1f}%)")
    print(f"\n  Detalhe PRE por categoria:")
    for cat, n in df.loc[df["is_pre"], "categoria_pre"].value_counts().items():
        print(f"    {cat:<25}: {n:>5d}")
    print(f"{'='*60}\n")


def conjunto_codigos_pre(df: pd.DataFrame, categoria: str | None = None) -> set:
    """
    Devolve o conjunto de CODIGO das unidades PRE.

    Parâmetros
    ──────────
    categoria : se fornecido, filtra por categoria_pre (ex: 'SOLAR_FOT').
                Se None, devolve todos os PRE.
    """
    mask = df["is_pre"]
    if categoria:
        mask = mask & (df["categoria_pre"] == categoria)
    return set(df.loc[mask, "CODIGO"])


# ─────────────────────────────────────────────────────────────────────────────
#  EXECUÇÃO DIRECTA (teste)
# ─────────────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    PATH = "./LISTA_UNIDADES.csv"   # ajustar conforme necessário

    df_unidades = carrega_unidades(PATH)
    resumo_classificacao(df_unidades)

    # Exemplos de uso
    todos_pre     = conjunto_codigos_pre(df_unidades)
    so_solar_fot  = conjunto_codigos_pre(df_unidades, "SOLAR_FOT")
    so_eolica     = conjunto_codigos_pre(df_unidades, "EOLICA")
    so_hidrica    = conjunto_codigos_pre(df_unidades, "HIDRICA")

    print(f"Códigos PRE total:      {len(todos_pre)}")
    print(f"Códigos Solar FV:       {len(so_solar_fot)}")
    print(f"Códigos Eólica:         {len(so_eolica)}")
    print(f"Códigos Hídrica RE:     {len(so_hidrica)}")

    print(f"\nExemplos Solar FV (10 primeiros):")
    print(sorted(so_solar_fot)[:10])

    print(f"\nExemplos Eólica (10 primeiros):")
    print(sorted(so_eolica)[:10])

    # Guardar CSV classificado
    df_unidades.to_csv("unidades_classificadas.csv", sep=";",
                       index=False, encoding="utf-8-sig", decimal=",")
    print("\nFicheiro 'unidades_classificadas.csv' guardado.")